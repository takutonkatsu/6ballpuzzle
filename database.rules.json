{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": true,
      ".write": true
    },
    "matchmaking": {
      ".read": true,
      ".write": true,
      ".indexOn": ["rating", "timestamp", "joinedAt"]
    },
    "arena_matchmaking": {
      ".read": true,
      ".write": true,
      ".indexOn": ["wins", "timestamp", "joinedAt"]
    },
    "rooms": {
      ".read": true,
      ".write": true
    },
    "rankings": {
      "global": {
        ".read": true,
        ".write": true,
        ".indexOn": ["rating", "updatedAt"]
      }
    },
    "reports": {
      ".read": false,
      ".write": true,
      ".indexOn": ["reportedUid", "createdAt"]
    }
  }
}
